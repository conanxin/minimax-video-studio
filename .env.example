MINIMAX_API_KEY=replace_with_your_minimax_token_plan_key
SITE_PASSCODE=change_me
PORT=8789
DATABASE_PATH=./data/minimax-video-studio.sqlite
MINIMAX_API_BASE=https://api.minimaxi.com
CONFIRM_REAL_VIDEO=0

# --- Access-tier configuration (Phase Q) -----------------------------
# REQUIRE_SITE_PASSCODE controls the in-app SITE_PASSCODE middleware.
#   true   -> default; passcode is required for /api/tasks,
#             /api/video/create, /api/video/task/:id,
#             /api/video/file/:id, /api/video/file/:id/refresh.
#   false  -> passcode is NOT required (skip the middleware entirely).
#             Intended for deployments already protected upstream by
#             Cloudflare Access (or an equivalent IdP-fronted reverse
#             proxy). Accepted off values: false / 0 / no / off.
#
# CLOUDFLARE_ACCESS_EXPECTED is a UI hint surfaced through
# /api/runtime-config so the frontend can show "Access is protected by
# Cloudflare Access." instead of asking for a passcode. It does NOT
# change any server-side enforcement. Accepted on values:
# true / 1 / yes / on.
#REQUIRE_SITE_PASSCODE=true
#CLOUDFLARE_ACCESS_EXPECTED=true
