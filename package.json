{
  "name": "minimax-video-studio",
  "version": "0.1.0",
  "private": true,
  "description": "MiniMax Text-to-Video MVP for Token Plan.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "nodemon server/index.js",
    "dev:web": "vite --config web/vite.config.js",
    "build": "vite build --config web/vite.config.js",
    "start": "node server/index.js",
    "smoke:video": "node scripts/smoke-text-to-video.js",
    "smoke:i2v": "node scripts/smoke-image-to-video.js",
    "import:local-smoke": "node scripts/import-local-smoke-to-db.js",
    "check:api": "node scripts/check-api-regression.js",
    "check:open-source": "node scripts/check-open-source.js",
    "check:minimax-auth": "node scripts/check-minimax-auth.js",
    "fixture:i2v:generate": "node scripts/generate-i2v-fixture.js",
    "fixture:i2v:validate": "node scripts/validate-i2v-fixture.js"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.3",
    "nodemon": "^3.1.9",
    "pngjs": "^7.0.0",
    "vite": "^5.4.17"
  }
}
